<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI 技术热点 · {{ report.date }}</title>
<style>
  :root{
    --bg:#0B0F1A; --bg-card:rgba(255,255,255,.04); --border:rgba(255,255,255,.08);
    --text:#E6EAF2; --muted:#8A93A6; --dim:#5A6378; --bright:#C8CED9;
    --accent:#22D3EE; --accent2:#A78BFA; --green:#4ADE80;
    --grad:linear-gradient(135deg,#22D3EE 0%,#A78BFA 100%);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);background-image:radial-gradient(900px 500px at 80% -10%,rgba(167,139,250,.15),transparent),radial-gradient(700px 400px at 0% 0%,rgba(34,211,238,.12),transparent);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;line-height:1.6;padding:20px}
  .wrap{max-width:1120px;margin:0 auto}
  header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:18px}
  .brand{display:flex;align-items:center;gap:14px}
  .logo{width:46px;height:46px;border-radius:13px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow:0 8px 24px rgba(34,211,238,.3)}
  h1{font-size:24px;font-weight:700;letter-spacing:.5px}
  .sub{color:var(--muted);font-size:13px}
  .date-pill{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;background:var(--bg-card);border:1px solid var(--border);padding:8px 14px;border-radius:999px;font-size:13px;color:var(--bright)}

  .editorial{background:linear-gradient(135deg,rgba(34,211,238,.08),rgba(167,139,250,.08));border:1px solid var(--border);backdrop-filter:blur(10px);border-radius:18px;padding:20px 22px;margin-bottom:18px}
  .editorial h2{font-size:15px;color:var(--accent);margin-bottom:12px;letter-spacing:.5px}
  .editorial ul{list-style:none;display:flex;flex-direction:column;gap:10px}
  .editorial li{font-size:14.5px;padding-left:18px;position:relative;color:var(--bright)}
  .editorial li::before{content:"▸";position:absolute;left:0;color:var(--accent2)}
  .ref{margin-left:6px;color:var(--accent);text-decoration:none;font-size:12px}

  .srcnav{position:sticky;top:0;z-index:10;display:flex;gap:8px;overflow-x:auto;padding:10px 0;margin-bottom:18px;background:linear-gradient(var(--bg),var(--bg)) no-repeat;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px)}
  .srcnav a{flex:0 0 auto;background:var(--bg-card);border:1px solid var(--border);color:var(--muted);text-decoration:none;padding:6px 14px;border-radius:999px;font-size:13px;white-space:nowrap;transition:color .15s,border-color .15s}
  .srcnav a:hover{color:var(--accent);border-color:rgba(34,211,238,.4)}

  .sections{display:flex;flex-direction:column;gap:18px}
  .card{background:var(--bg-card);border:1px solid var(--border);backdrop-filter:blur(10px);border-radius:18px;padding:18px 20px;scroll-margin-top:64px}
  .card h3{font-size:16px;margin-bottom:14px;display:flex;align-items:center;gap:8px}
  .count{margin-left:auto;color:var(--dim);font-size:12px;font-family:ui-monospace,monospace;font-weight:400}

  .items{list-style:none;display:flex;flex-direction:column;gap:10px}
  .item{display:flex;gap:12px;padding:12px 14px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.05);border-radius:12px;transition:border-color .15s,background .15s;scroll-margin-top:64px}
  .item:hover{border-color:rgba(34,211,238,.3);background:rgba(255,255,255,.04)}
  .rank{flex:0 0 auto;width:22px;height:22px;border-radius:6px;background:rgba(255,255,255,.06);color:var(--muted);font-size:11px;display:flex;align-items:center;justify-content:center;font-family:ui-monospace,monospace;margin-top:1px}
  .body{flex:1;min-width:0}
  .item-head{display:flex;align-items:baseline;gap:8px;flex-wrap:wrap}
  .item-title{color:var(--text);text-decoration:none;font-size:14.5px;font-weight:600;border-bottom:1px solid transparent;transition:color .15s,border-color .15s;word-break:break-word}
  .item-title:hover{color:var(--accent);border-bottom-color:var(--accent)}
  .chips{display:inline-flex;gap:4px;flex-wrap:wrap}
  .chip{font-size:10.5px;padding:1px 8px;border-radius:999px;white-space:nowrap}
  .chip:nth-child(odd){background:rgba(34,211,238,.14);color:var(--accent)}
  .chip:nth-child(even){background:rgba(167,139,250,.14);color:var(--accent2)}
  .item-summary{color:var(--bright);font-size:13px;margin-top:5px;line-height:1.55}
  .item-meta{color:var(--dim);font-size:11.5px;margin-top:5px}
  .item-foot{margin-top:7px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px}
  .metric{color:var(--accent)}
  .trend{color:var(--green)}
  .domain{color:var(--muted);text-decoration:none;margin-left:auto}
  .domain:hover{color:var(--accent2)}
  .empty{color:var(--muted);font-style:italic;font-size:13px;padding:8px 0}

  footer{text-align:center;color:var(--dim);font-size:12px;margin-top:26px;font-family:ui-monospace,monospace}
  @media (max-width:720px){body{padding:14px}.item-foot{font-size:11.5px}.domain{margin-left:0}}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="brand">
      <div class="logo">🤖</div>
      <div>
        <h1>AI 技术热点</h1>
        <div class="sub">Daily AI Tech Digest · 模型 / 论文 / 开源 / 社区</div>
      </div>
    </div>
    <div class="date-pill">{{ report.date }} {{ report.weekday }}</div>
  </header>

  {% if report.editorial %}
  <section class="editorial">
    <h2>📌 今日要点 · AI 编辑</h2>
    <ul>
      {% for e in report.editorial %}
      <li>{{ e.text }}{% if e.refs %}<a class="ref" href="#{{ e.refs[0] }}" title="跳转到条目">🔗</a>{% endif %}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <nav class="srcnav">
    {% for s in report.sources %}
    <a href="#src-{{ s.key }}">{{ s.icon }} {{ s.label }}</a>
    {% endfor %}
  </nav>

  <div class="sections">
    {% for s in report.sources %}
    <section class="card" id="src-{{ s.key }}">
      <h3><span>{{ s.icon }}</span> {{ s.label }}<span class="count">{{ s["items"] | length }} 条</span></h3>
      {% if s["items"] %}
      <ol class="items">
        {% for it in s["items"] %}
        <li class="item" id="{{ it.key }}">
          <div class="rank">{{ loop.index }}</div>
          <div class="body">
            <div class="item-head">
              <a class="item-title" href="{{ it.url }}" target="_blank" rel="noopener">{{ it.title }}</a>
              {% if it.tags %}<span class="chips">{% for t in it.tags %}<span class="chip">{{ t }}</span>{% endfor %}</span>{% endif %}
            </div>
            {% if it.summary %}<div class="item-summary">{{ it.summary }}</div>{% endif %}
            {% if it.meta %}<div class="item-meta">{{ it.meta }}</div>{% endif %}
            <div class="item-foot">
              {% if it.score_label %}<span class="metric">{{ it.score_label }}</span>{% endif %}
              {% if it.trend %}<span class="trend">{{ it.trend }}</span>{% endif %}
              {% if it.domain %}<a class="domain" href="{{ it.url }}" target="_blank" rel="noopener">🔗 {{ it.domain }}</a>{% endif %}
            </div>
          </div>
        </li>
        {% endfor %}
      </ol>
      {% else %}
      <div class="empty">该源获取失败，稍后重试</div>
      {% endif %}
    </section>
    {% endfor %}
  </div>

  <footer>数据源 {{ report.source_count }} · 共 {{ report.total }} 条 · 生成于 {{ report.date }} · by Claude</footer>
</div>
</body>
</html>
